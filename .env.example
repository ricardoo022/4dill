# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/lusitaidb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=lusitaidb

# === LLM Providers ===
GENERATOR_MODEL=gpt-4.1-mini   # provider:model or bare name — e.g. openai:gpt-4o, anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
# OLLAMA_SERVER_URL=http://localhost:11434

# === Docker ===
DOCKER_INSIDE=true
DOCKER_DEFAULT_IMAGE=kalilinux/kali-rolling

# === Neo4j / Graphiti ===
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
GRAPHITI_ENABLED=false
GRAPHITI_URL=http://graphiti:8000
GRAPHITI_TIMEOUT=30

# === Search ===
# TAVILY_API_KEY=tvly-xxx
# SEARXNG_URL=http://searxng:8080

# === Observability ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=ls__xxx
LANGSMITH_PROJECT=lusitai-aipentest

# === PortSwigger ===
# PORTSWIGGER_EMAIL=

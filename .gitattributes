# Normalize all text files to LF in the repo (safe default)
* text=auto eol=lf

# Explicitly LF for code and config
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.j2        text eol=lf
*.sh        text eol=lf
*.txt       text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf
*.sql       text eol=lf
Dockerfile  text eol=lf

# Binary — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.tar   binary
*.gz    binary
